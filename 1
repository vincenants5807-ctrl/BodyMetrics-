<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BodyMetrics - 身体数据追踪与分析</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Segoe UI',sans-serif;background:#0f1117;color:#e2e8f0;min-height:100vh;}
.app{max-width:960px;margin:0 auto;padding:20px;}
.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;}
.header h1{font-size:22px;color:#f59e0b;}
.header-btns button{padding:7px 14px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:7px;color:#e2e8f0;cursor:pointer;font-size:11px;margin-left:6px;}

.metric-cards{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px;}
.mc{padding:16px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:12px;text-align:center;position:relative;}
.mc .mc-icon{font-size:22px;margin-bottom:6px;}
.mc .mc-val{font-size:28px;font-weight:bold;color:#f59e0b;font-family:'Fira Code',monospace;}
.mc .mc-label{font-size:10px;opacity:.4;margin-top:2px;}
.mc .mc-delta{position:absolute;top:10px;right:10px;font-size:10px;padding:2px 6px;border-radius:4px;}
.mc .mc-delta.up{color:#22c55e;background:rgba(34,197,94,.1);}
.mc .mc-delta.down{color:#ef4444;background:rgba(239,68,68,.1);}

.tabs{display:flex;gap:6px;margin-bottom:20px;flex-wrap:wrap;}
.tab{padding:8px 16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;cursor:pointer;font-size:12px;transition:.2s;}
.tab:hover,.tab.active{background:rgba(245,158,11,.12);border-color:#f59e0b;color:#f59e0b;}

.view{display:none;}
.view.active{display:block;}

/* 录入 */
.input-section{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;}
.input-card{padding:16px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:12px;}
.input-card h3{font-size:12px;color:#f59e0b;margin-bottom:10px;}
.inp-row{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.inp-row label{font-size:12px;opacity:.6;min-width:70px;}
.inp-row input{flex:1;padding:8px 10px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:6px;color:#e2e8f0;font-size:13px;}
.inp-row select{flex:1;padding:8px 10px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:6px;color:#e2e8f0;font-size:13px;}
.save-btn{width:100%;padding:10px;background:linear-gradient(135deg,#f59e0b,#d97706);border:none;border-radius:8px;color:#0f1117;font-weight:700;font-size:13px;cursor:pointer;margin-top:8px;transition:.2s;}
.save-btn:hover{transform:scale(1.01);box-shadow:0 4px 12px rgba(245,158,11,.3);}

/* BMI 仪表盘 */
.bmi-dashboard{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;}
.bmi-gauge{padding:20px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:14px;text-align:center;}
.bmi-gauge canvas{margin:10px auto;}
.bmi-gauge .bmi-val{font-size:36px;font-weight:bold;color:#f59e0b;font-family:'Fira Code',monospace;}
.bmi-gauge .bmi-label{font-size:13px;margin-top:4px;}
.bmi-info{padding:20px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:14px;}
.bi-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:12px;}
.bi-row .bk{opacity:.5;}
.bi-row .bv{color:#f59e0b;font-family:'Fira Code',monospace;}
.bmi-bar{height:8px;border-radius:4px;background:linear-gradient(90deg,#3b82f6 0%,#22c55e 30%,#fbbf24 55%,#ef4444 80%,#dc2626 100%);margin:12px 0;position:relative;}
.bmi-marker{position:absolute;top:-4px;width:4px;height:16px;background:#fff;border-radius:2px;transform:translateX(-50%);}

/* 图表 */
.chart-area{padding:20px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.06);border-radius:14px;margin-bottom:16px;}
.chart-area h3{font-size:12px;color:#f59e0b;margin-bottom:10px;}
canvas.chart{width:100%;height:180px;}

/* 日历热力图 */
.heatmap{display:flex;gap:2px;flex-wrap:wrap;margin-top:10px;}
.hm-day{width:14px;height:14px;border-radius:3px;cursor:pointer;position:relative;}
.hm-day:hover::after{content:attr(data-tip);position:absolute;bottom:18px;left:50%;transform:translateX(-50%);background:#1e293b;padding:3px 6px;border-radius:4px;font-size:9px;white-space:nowrap;z-index:10;}

/* 卡路里计算器 */
.calc-section{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.calc-card{padding:18px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:12px;}
.calc-card h3{font-size:12px;color:#f59e0b;margin-bottom:10px;}
.calc-result{padding:16px;background:rgba(245,158,11,.05);border:1px solid rgba(245,158,11,.2);border-radius:10px;margin-top:10px;text-align:center;}
.calc-result .cr-val{font-size:32px;font-weight:bold;color:#f59e0b;font-family:'Fira Code',monospace;}
.calc-result .cr-label{font-size:11px;opacity:.4;margin-top:4px;}
.macro-bar{display:flex;height:8px;border-radius:4px;overflow:hidden;margin-top:10px;}
.macro-bar div{height:100%;}
.macro-legend{display:flex;gap:12px;margin-top:6px;font-size:10px;}
.macro-legend span::before{content:'';display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:4px;vertical-align:middle;}
</style>
</head>
<body>
<div class="app">
  <div class="header">
    <h1>📊 BodyMetrics</h1>
    <div class="header-btns">
      <button onclick="exportData()">📤 导出</button>
      <button onclick="importData()">📥 导入</button>
      <button onclick="clearData()">🗑 清空</button>
    </div>
  </div>

  <div class="metric-cards" id="metricCards"></div>

  <div class="tabs">
    <div class="tab active" onclick="showView('record')">📝 记录</div>
    <div class="tab" onclick="showView('bmi')">📐 BMI</div>
    <div class="tab" onclick="showView('trend')">📈 趋势</div>
    <div class="tab" onclick="showView('calorie')">🔥 热量</div>
  </div>

  <div class="view active" id="vRecord">
    <div class="input-section">
      <div class="input-card">
        <h3>⚖️ 身体数据</h3>
        <div class="inp-row"><label>体重 (kg)</label><input type="number" id="inWeight" step="0.1" placeholder="70.0"></div>
        <div class="inp-row"><label>身高 (cm)</label><input type="number" id="inHeight" step="0.1" placeholder="175.0"></div>
        <div class="inp-row"><label>腰围 (cm)</label><input type="number" id="inWaist" step="0.1" placeholder="80.0"></div>
        <div class="inp-row"><label>体脂率 (%)</label><input type="number" id="inBodyFat" step="0.1" placeholder="20.0"></div>
      </div>
      <div class="input-card">
        <h3>🏃 运动数据</h3>
        <div class="inp-row"><label>运动类型</label><select id="inExType"><option value="跑步">🏃 跑步</option><option value="力量">🏋️ 力量训练</option><option value="游泳">🏊 游泳</option><option value="骑行">🚴 骑行</option><option value="瑜伽">🧘 瑜伽</option><option value="HIIT">⚡ HIIT</option><option value="走路">🚶 走路</option><option value="其他">📌 其他</option></select></div>
        <div class="inp-row"><label>时长 (分)</label><input type="number" id="inDuration" placeholder="30"></div>
        <div class="inp-row"><label>消耗 (kcal)</label><input type="number" id="inCalBurn" placeholder="300"></div>
        <div class="inp-row"><label>备注</label><input id="inNote" placeholder="今日感受..."></div>
      </div>
    </div>
    <button class="save-btn" onclick="saveRecord()">💾 保存今日记录</button>
    <div style="margin-top:16px;">
      <h3 style="font-size:12px;color:#f59e0b;margin-bottom:8px;">📅 记录热力图 (近90天)</h3>
      <div class="heatmap" id="heatmap"></div>
    </div>
  </div>

  <div class="view" id="vBmi">
    <div class="bmi-dashboard">
      <div class="bmi-gauge">
        <h3 style="font-size:12px;opacity:.5;">BMI 指数</h3>
        <canvas id="bmiGauge" width="200" height="120"></canvas>
        <div class="bmi-val" id="bmiVal">--</div>
        <div class="bmi-label" id="bmiLabel">请先录入身高体重</div>
        <div class="bmi-bar"><div class="bmi-marker" id="bmiMarker" style="left:50%"></div></div>
      </div>
      <div class="bmi-info">
        <h3 style="font-size:12px;color:#f59e0b;margin-bottom:10px;">📋 身体评估</h3>
        <div id="bmiDetails"></div>
      </div>
    </div>
  </div>

  <div class="view" id="vTrend">
    <div class="chart-area"><h3>⚖️ 体重趋势</h3><canvas class="chart" id="weightChart" height="180"></canvas></div>
    <div class="chart-area"><h3>📐 体脂率趋势</h3><canvas class="chart" id="fatChart" height="180"></canvas></div>
    <div class="chart-area"><h3>🔥 每日消耗趋势</h3><canvas class="chart" id="calChart" height="180"></canvas></div>
  </div>

  <div class="view" id="vCalorie">
    <div class="calc-section">
      <div class="calc-card">
        <h3>🔥 每日热量需求 (TDEE)</h3>
        <div class="inp-row"><label>性别</label><select id="cGender"><option value="male">男</option><option value="female">女</option></select></div>
        <div class="inp-row"><label>年龄</label><input type="number" id="cAge" value="25"></div>
        <div class="inp-row"><label>身高 (cm)</label><input type="number" id="cHeight" value="175"></div>
        <div class="inp-row"><label>体重 (kg)</label><input type="number" id="cWeight" value="70"></div>
        <div class="inp-row"><label>活动量</label><select id="cActivity"><option value="1.2">久坐 (办公室)</option><option value="1.375">轻度活动 (1-3天/周)</option><option value="1.55" selected>中度活动 (3-5天/周)</option><option value="1.725">高度活动 (6-7天/周)</option><option value="1.9">极高活动 (运动员)</option></select></div>
        <button class="save-btn" onclick="calcTDEE()">计算 TDEE</button>
        <div class="calc-result" id="tdeeResult" style="display:none;"></div>
      </div>
      <div class="calc-card">
        <h3>🎯 目标热量分配</h3>
        <div class="inp-row"><label>目标</label><select id="cGoal" onchange="updateGoalCalc()"><option value="lose">减脂 (-500kcal)</option><option value="maintain">维持</option><option value="gain">增肌 (+300kcal)</option></select></div>
        <div class="calc-result" id="goalResult" style="display:none;"></div>
        <div style="margin-top:12px;">
          <h4 style="font-size:11px;opacity:.5;margin-bottom:6px;">宏量营养素分配</h4>
          <div class="macro-bar" id="macroBar"></div>
          <div class="macro-legend" id="macroLegend"></div>
        </div>
        <div id="macroDetails" style="margin-top:10px;"></div>
      </div>
    </div>
  </div>
</div>

<script>
let DB = JSON.parse(localStorage.getItem('bodymetrics_db')||'{"records":[],"profile":{}}');
const TODAY = new Date().toISOString().split('T')[0];

function save(){ localStorage.setItem('bodymetrics_db', JSON.stringify(DB)); }

// ====== 视图切换 ======
function showView(name){
    document.querySelectorAll('.tab').forEach((t,i)=>t.classList.toggle('active',['record','bmi','trend','calorie'][i]===name));
    document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
    document.getElementById('v'+name.charAt(0).toUpperCase()+name.slice(1)).classList.add('active');
    if(name==='bmi') updateBMI();
    if(name==='trend') drawCharts();
}

// ====== 记录保存 ======
function saveRecord(){
    const record = {
        date: TODAY,
        weight: parseFloat(document.getElementById('inWeight').value)||null,
        height: parseFloat(document.getElementById('inHeight').value)||null,
        waist: parseFloat(document.getElementById('inWaist').value)||null,
        bodyFat: parseFloat(document.getElementById('inBodyFat').value)||null,
        exercise: document.getElementById('inExType').value,
        duration: parseInt(document.getElementById('inDuration').value)||0,
        calBurn: parseInt(document.getElementById('inCalBurn').value)||0,
        note: document.getElementById('inNote').value
    };
    // 更新或添加
    const idx = DB.records.findIndex(r=>r.date===TODAY);
    if(idx>=0) Object.assign(DB.records[idx], record);
    else DB.records.push(record);
    // 更新 profile
    if(record.height) DB.profile.height = record.height;
    if(record.weight) DB.profile.weight = record.weight;
    save();
    updateMetricCards();
    renderHeatmap();
    alert('✅ 记录已保存!');
}

// ====== 指标卡片 ======
function updateMetricCards(){
    const latest = DB.records.filter(r=>r.weight).sort((a,b)=>b.date.localeCompare(a.date));
    const cur = latest[0], prev = latest[1];
    const totalCal = DB.records.reduce((s,r)=>s+r.calBurn,0);
    const totalMin = DB.records.reduce((s,r)=>s+r.duration,0);
    const streak = calcStreak();

    const cards = [
        {icon:'⚖️', val:cur?cur.weight.toFixed(1):'--', label:'当前体重 (kg)', delta:cur&&prev?(cur.weight-prev.weight).toFixed(1):null, inverse:true},
        {icon:'📐', val:cur&&cur.bodyFat?cur.bodyFat.toFixed(1)+'%':'--', label:'体脂率', delta:null},
        {icon:'🔥', val:totalCal, label:'累计消耗 (kcal)', delta:null},
        {icon:'📅', val:streak, label:'连续打卡 (天)', delta:null}
    ];
    document.getElementById('metricCards').innerHTML = cards.map(c=>{
        let deltaHtml='';
        if(c.delta!==null && c.delta!==undefined){
            const num=parseFloat(c.delta);
            const cls=(c.inverse?num>0:num<0)?'down':'up';
            deltaHtml=`<div class="mc-delta ${num>0?(c.inverse?'down':'up'):(c.inverse?'up':'down')}">${num>0?'+':''}${c.delta}</div>`;
        }
        return `<div class="mc">${deltaHtml}<div class="mc-icon">${c.icon}</div><div class="mc-val">${c.val}</div><div class="mc-label">${c.label}</div></div>`;
    }).join('');
}

function calcStreak(){
    let s=0;
    for(let i=0;i<365;i++){
        const d=new Date(Date.now()-i*864e5).toISOString().split('T')[0];
        if(DB.records.some(r=>r.date===d)) s++; else break;
    }
    return s;
}

// ====== 热力图 ======
function renderHeatmap(){
    let html='';
    for(let i=89;i>=0;i--){
        const d=new Date(Date.now()-i*864e5).toISOString().split('T')[0];
        const rec=DB.records.find(r=>r.date===d);
        let color='rgba(255,255,255,.04)';
        let tip=d;
        if(rec){
            const intensity = Math.min(1, (rec.calBurn||0)/500);
            color = `rgba(245,158,11,${0.15+intensity*0.6})`;
            tip = `${d}: ${rec.calBurn||0}kcal`;
        }
        html+=`<div class="hm-day" style="background:${color}" data-tip="${tip}"></div>`;
    }
    document.getElementById('heatmap').innerHTML=html;
}

// ====== BMI ======
function updateBMI(){
    const h=DB.profile.height, w=DB.profile.weight;
    if(!h||!w){
        document.getElementById('bmiVal').textContent='--';
        document.getElementById('bmiLabel').textContent='请先录入身高体重';
        return;
    }
    const bmi = w/((h/100)**2);
    document.getElementById('bmiVal').textContent = bmi.toFixed(1);
    let label='', color='';
    if(bmi<18.5){label='偏瘦';color='#3b82f6';}
    else if(bmi<24){label='正常';color='#22c55e';}
    else if(bmi<28){label='偏胖';color='#fbbf24';}
    else{label='肥胖';color='#ef4444';}
    document.getElementById('bmiLabel').innerHTML=`<span style="color:${color}">${label}</span>`;
    // marker
    const pct=Math.min(100,Math.max(0,(bmi-15)/(40-15)*100));
    document.getElementById('bmiMarker').style.left=pct+'%';
    // details
    const idealMin=(18.5*(h/100)**2).toFixed(1), idealMax=(24*(h/100)**2).toFixed(1);
    const bmr = DB.profile.gender==='female'?
        655.1+9.563*w+1.85*h-4.676*25 :
        66.47+13.75*w+5.003*h-6.755*25;
    document.getElementById('bmiDetails').innerHTML = `
        <div class="bi-row"><span class="bk">BMI</span><span class="bv">${bmi.toFixed(1)}</span></div>
        <div class="bi-row"><span class="bk">状态</span><span class="bv" style="color:${color}">${label}</span></div>
        <div class="bi-row"><span class="bk">正常体重范围</span><span class="bv">${idealMin}-${idealMax} kg</span></div>
        <div class="bi-row"><span class="bk">基础代谢 (BMR)</span><span class="bv">${Math.round(bmr)} kcal</span></div>
        <div class="bi-row"><span class="bk">身高</span><span class="bv">${h} cm</span></div>
        <div class="bi-row"><span class="bk">体重</span><span class="bv">${w} kg</span></div>
    `;
    drawBMIGauge(bmi);
}

function drawBMIGauge(bmi){
    const c=document.getElementById('bmiGauge');
    const ctx=c.getContext('2d');
    ctx.clearRect(0,0,200,120);
    // 半圆
    const cx=100,cy=100,r=80;
    const colors=[{angle:0,color:'#3b82f6'},{angle:0.28,color:'#22c55e'},{angle:0.55,color:'#fbbf24'},{angle:0.8,color:'#ef4444'}];
    colors.forEach((c2,i)=>{
        const next=colors[i+1]||{angle:1};
        ctx.beginPath();
        ctx.arc(cx,cy,r,Math.PI+c2.angle*Math.PI, Math.PI+next.angle*Math.PI);
        ctx.strokeStyle=c2.color; ctx.lineWidth=12; ctx.lineCap='round'; ctx.stroke();
    });
    // 指针
    const angle=Math.PI+Math.min(1,Math.max(0,(bmi-15)/(40-15)))*Math.PI;
    ctx.save(); ctx.translate(cx,cy); ctx.rotate(angle);
    ctx.fillStyle='#fff'; ctx.beginPath();
    ctx.moveTo(-3,0); ctx.lineTo(0,-r+20); ctx.lineTo(3,0); ctx.closePath(); ctx.fill();
    ctx.restore();
    ctx.fillStyle='#fff'; ctx.beginPath(); ctx.arc(cx,cy,6,0,Math.PI*2); ctx.fill();
}

// ====== 趋势图 ======
function drawCharts(){
    drawLineChart('weightChart', DB.records.filter(r=>r.weight).slice(-30), 'weight', '#f59e0b');
    drawLineChart('fatChart', DB.records.filter(r=>r.bodyFat).slice(-30), 'bodyFat', '#a78bfa');
    drawLineChart('calChart', DB.records.filter(r=>r.calBurn).slice(-30), 'calBurn', '#22c55e');
}

function drawLineChart(canvasId, data, key, color){
    const canvas=document.getElementById(canvasId);
    if(!canvas) return;
    const ctx=canvas.getContext('2d');
    const dpr=devicePixelRatio||1;
    canvas.width=canvas.offsetWidth*dpr; canvas.height=360;
    ctx.scale(dpr,dpr);
    const w=canvas.offsetWidth, h=180;
    ctx.clearRect(0,0,w,h);
    if(data.length<2){ctx.fillStyle='rgba(255,255,255,.2)';ctx.font='12px sans-serif';ctx.fillText('数据不足，至少需要2条记录',w/2-80,h/2);return;}
    const vals=data.map(d=>d[key]);
    const max=Math.max(...vals)*1.05, min=Math.min(...vals)*0.95;
    const range=max-min||1;
    // 网格
    ctx.strokeStyle='rgba(255,255,255,.04)'; ctx.lineWidth=1;
    for(let i=0;i<5;i++){const y=20+i*(h-40)/4; ctx.beginPath(); ctx.moveTo(30,y); ctx.lineTo(w-10,y); ctx.stroke();}
    // 折线
    ctx.strokeStyle=color; ctx.lineWidth=2.5; ctx.beginPath();
    data.forEach((d,i)=>{
        const x=30+i*(w-40)/(data.length-1);
        const y=20+(1-(d[key]-min)/range)*(h-40);
        i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
    });
    ctx.stroke();
    // 填充
    const lastX=30+(data.length-1)*(w-40)/(data.length-1);
    ctx.lineTo(lastX,h-20); ctx.lineTo(30,h-20); ctx.closePath();
    ctx.fillStyle=color+'15'; ctx.fill();
    // 点
    data.forEach((d,i)=>{
        const x=30+i*(w-40)/(data.length-1);
        const y=20+(1-(d[key]-min)/range)*(h-40);
        ctx.fillStyle=color; ctx.beginPath(); ctx.arc(x,y,3,0,Math.PI*2); ctx.fill();
    });
    // Y 轴标签
    ctx.fillStyle='rgba(255,255,255,.3)';ctx.font='9px Fira Code,monospace';ctx.textAlign='right';
    for(let i=0;i<5;i++){
        const v=max-(i/(4))*(max-min);
        ctx.fillText(v.toFixed(1),28,24+i*(h-40)/4);
    }
}

// ====== TDEE 计算 ======
function calcTDEE(){
    const gender=document.getElementById('cGender').value;
    const age=parseInt(document.getElementById('cAge').value);
    const h=parseFloat(document.getElementById('cHeight').value);
    const w=parseFloat(document.getElementById('cWeight').value);
    const act=parseFloat(document.getElementById('cActivity').value);
    let bmr;
    if(gender==='male') bmr=66.47+13.75*w+5.003*h-6.755*age;
    else bmr=655.1+9.563*w+1.85*h-4.676*age;
    const tdee=Math.round(bmr*act);
    document.getElementById('tdeeResult').style.display='block';
    document.getElementById('tdeeResult').innerHTML=`
        <div class="cr-val">${tdee}</div><div class="cr-label">每日总热量消耗 (TDEE) kcal</div>
        <div style="font-size:11px;opacity:.5;margin-top:6px;">基础代谢 BMR = ${Math.round(bmr)} kcal</div>`;
    DB.profile.tdee=tdee; DB.profile.bmr=Math.round(bmr); save();
    updateGoalCalc();
}

function updateGoalCalc(){
    const tdee=DB.profile.tdee;
    if(!tdee) return;
    const goal=document.getElementById('cGoal').value;
    const adj=goal==='lose'?-500:goal==='gain'?300:0;
    const target=tdee+adj;
    document.getElementById('goalResult').style.display='block';
    document.getElementById('goalResult').innerHTML=`<div class="cr-val">${target}</div><div class="cr-label">每日目标摄入 kcal (${goal==='lose'?'减脂':goal==='gain'?'增肌':'维持'})</div>`;
    // 宏量
    const proteinPct=goal==='gain'?0.3:goal==='lose'?0.35:0.25;
    const fatPct=0.25;
    const carbPct=1-proteinPct-fatPct;
    const proteinG=Math.round(target*proteinPct/4);
    const fatG=Math.round(target*fatPct/9);
    const carbG=Math.round(target*carbPct/4);
    document.getElementById('macroBar').innerHTML=`
        <div style="width:${proteinPct*100}%;background:#ef4444;"></div>
        <div style="width:${fatPct*100}%;background:#fbbf24;"></div>
        <div style="width:${carbPct*100}%;background:#3b82f6;"></div>`;
    document.getElementById('macroLegend').innerHTML=`
        <span style="color:#ef4444;">● 蛋白质 ${Math.round(proteinPct*100)}%</span>
        <span style="color:#fbbf24;">● 脂肪 ${Math.round(fatPct*100)}%</span>
        <span style="color:#3b82f6;">● 碳水 ${Math.round(carbPct*100)}%</span>`;
    document.getElementById('macroDetails').innerHTML=`
        <div class="bi-row"><span class="bk">蛋白质</span><span class="bv">${proteinG}g</span></div>
        <div class="bi-row"><span class="bk">脂肪</span><span class="bv">${fatG}g</span></div>
        <div class="bi-row"><span class="bk">碳水化合物</span><span class="bv">${carbG}g</span></div>`;
}

// ====== 导入导出 ======
function exportData(){
    const blob=new Blob([JSON.stringify(DB,null,2)],{type:'application/json'});
    const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='bodymetrics_export.json';a.click();
}
function importData(){
    const inp=document.createElement('input');inp.type='file';inp.accept='.json';
    inp.onchange=e=>{const r=new FileReader();r.onload=ev=>{try{DB=JSON.parse(ev.target.result);save();updateMetricCards();renderHeatmap();alert('导入成功!');}catch(e){alert('导入失败');}};r.readAsText(e.target.files[0]);};inp.click();
}
function clearData(){if(confirm('确认清空所有数据?')){DB={records:[],profile:{}};save();updateMetricCards();renderHeatmap();}}

// ====== 初始化 ======
updateMetricCards();
renderHeatmap();
</script>
</body>
</html>
